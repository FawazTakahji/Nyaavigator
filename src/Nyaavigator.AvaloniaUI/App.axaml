<Application x:Class="Nyaavigator.AvaloniaUI.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Avalonia.Controls.Converters;assembly=Avalonia.Controls"
             xmlns:semi="https://irihi.tech/semi"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <semi:SemiTheme Locale="en-US" />
        <semi:UrsaSemiTheme Locale="en-US" />
        <StyleInclude Source="/Controls/Index.axaml" />

        <Style Selector="Button.HeaderButton">
            <Setter Property="Padding" Value="8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Theme" Value="{StaticResource BorderlessButton}" />

            <Style Selector="^ &gt; PathIcon">
                <Setter Property="Width" Value="18" />
                <Setter Property="Height" Value="18" />
            </Style>
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>