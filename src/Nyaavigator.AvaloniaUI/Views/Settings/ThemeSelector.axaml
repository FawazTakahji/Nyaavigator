<UserControl x:Class="Nyaavigator.AvaloniaUI.Views.Settings.ThemeSelector"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:Nyaavigator.Core.Settings;assembly=Nyaavigator.Core"
             xmlns:ui="clr-namespace:Nyaavigator.AvaloniaUI"
             xmlns:viewModels="clr-namespace:Nyaavigator.Core.ViewModels;assembly=Nyaavigator.Core"
             d:DesignHeight="450"
             d:DesignWidth="800"
             x:DataType="viewModels:SettingsViewModel"
             mc:Ignorable="d">
    <Design.DataContext>
        <ui:DesignServiceLocator Type="viewModels:SettingsViewModel" />
    </Design.DataContext>

    <Border Theme="{StaticResource RadioButtonGroupBorder}">
        <StackPanel>
            <StackPanel.Styles>
                <Style Selector="RadioButton">
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="Theme" Value="{DynamicResource ButtonRadioButton}" />
                </Style>
            </StackPanel.Styles>
            <StackPanel.Resources>
                <Thickness x:Key="RadioButtonButtonLargePadding">24 18</Thickness>
            </StackPanel.Resources>

            <RadioButton Margin="2,2,2,0"
                         Classes="Large"
                         Command="{Binding SetThemeCommand}"
                         CommandParameter="{x:Static settings:Theme.System}"
                         Content="System"
                         CornerRadius="3,3,0,0"
                         IsChecked="{Binding SettingsService.Settings.Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static settings:Theme.System}}" />
            <RadioButton Margin="2,0"
                         Classes="Large"
                         Command="{Binding SetThemeCommand}"
                         CommandParameter="{x:Static settings:Theme.Light}"
                         Content="Light"
                         CornerRadius="0"
                         IsChecked="{Binding SettingsService.Settings.Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static settings:Theme.Light}}" />
            <RadioButton Margin="2,0,2,2"
                         Classes="Large"
                         Command="{Binding SetThemeCommand}"
                         CommandParameter="{x:Static settings:Theme.Dark}"
                         Content="Dark"
                         CornerRadius="0,0,3,3"
                         IsChecked="{Binding SettingsService.Settings.Theme, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static settings:Theme.Dark}}" />
        </StackPanel>
    </Border>
</UserControl>
