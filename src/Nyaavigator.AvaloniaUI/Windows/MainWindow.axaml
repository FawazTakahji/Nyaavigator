<Window x:Class="Nyaavigator.AvaloniaUI.Windows.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Nyaavigator.Core;assembly=Nyaavigator.Core"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:Nyaavigator.AvaloniaUI.Views"
        Title="{x:Static core:Constants.Title}"
        d:DesignHeight="450"
        d:DesignWidth="800"
        Icon="/Assets/avalonia-logo.ico"
        mc:Ignorable="d">
    <views:MainView />
</Window>
